# ===========================================
# ソラしどファーム 管理システム 環境変数
# ===========================================
# このファイルを .env.local にコピーして値を設定してください
# cp .env.local.example .env.local

# --- Supabase ---
# Supabaseプロジェクトの Settings > API から取得
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# --- アクセス制限 ---
# 簡易パスワード保護（設定すると全ページにパスワード入力を要求）
# 未設定の場合はパスワードなしでアクセス可能
NEXT_PUBLIC_SITE_PASSWORD=your-password-here

# --- Stripe ---
# Stripe Payment Link (Stripe ダッシュボードで作成した Payment Link のURL)
# 設定すると会計ページに「Stripeで決済リンクを送る」ボタンが表示されます
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=https://buy.stripe.com/your-payment-link
